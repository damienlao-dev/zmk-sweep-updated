#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

// Home row mod macros
#define HRML(k2,k3,k4) &ht LALT k2  &ht LCTRL k3  &ht LGUI k4
#define HRMR(k1,k2,k3) &ht RGUI k1  &ht RCTRL k2  &ht RALT k3
#define WHRML(k2,k3,k4) &ht LALT k2  &ht LGUI k3  &ht LCTRL k4
#define WHRMR(k1,k2,k3) &ht RCTRL k1  &ht RGUI k2  &ht RALT k3

#define MAC 0
#define WIN 1
#define RIG 2
#define LEF 3
#define TRI 4

/ {
    behaviors {

        // General hold‑tap for home‑row mods
        ht: hold_tap {
            label = "hold_tap";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <220>;
            quick-tap-ms = <150>;
            global-quick-tap;
            bindings = <&kp>, <&kp>;
        };

        // Tap‑holds for QMK‑style LCTL_T, LSFT_T, RALT_T, etc.
        mt_ctl: mt_LCTL {
            label = "LCTL_TAP";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp LCTRL>;
        };

        mt_sft: mt_LSFT {
            label = "LSFT_TAP";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp LSHIFT>;
        };

        mt_ralt: mt_RALT {
            label = "RALT_TAP";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp RALT>;
        };

        // Mouse‑wheel / mouse pointer holds
        mt_wh_u: mt_WH_U {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp WH_U>;
        };
        mt_wh_d: mt_WH_D {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp WH_D>;
        };
        mt_wh_l: mt_WH_L {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp WH_L>;
        };
        mt_wh_r: mt_WH_R {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp WH_R>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        tri_layer {
            if-layers = <RIG LEF>;
            then-layer = <TRI>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // Default typing layer (QMK layer 0)
        default_layer {
            bindings = <
                // Left half – top row
                &kp Q      &kp W      &kp E      &kp R      &kp T
                // Left row 2 – home row mods + LCTL
                &kp A      HRML(S,         D,         F)     &mt_ctl G
                // Left row 3 – bottom row
                &kp Z      &kp X      &kp C      &kp V      &kp B
                // Thumb row – left
                &lt LEF TAB  &kp SPACE  &trans     &trans     &trans

                // Right half – top row
                &kp Y      &kp U      &kp I      &kp O      &kp P
                // Right row 2 – LCTL / LSFT mods + RALT quote
                &kp H      &mt_ctl J  &mt_sft K  &kp L      &kp QUOTE
                // Right row 3 – bottom row
                &kp N      &kp M      &kp COMMA  &kp DOT    &mt_sft SLASH
                // Thumb row – right
                &kp BSPC   &lt RIG TAB  &trans     &trans     &trans
            >;
        };

        // Windows‑style home‑row mod order (QMK layer 0 alt mapping)
        windows_layer {
            bindings = <
                // Same layout, reordered home‑row mods
                &kp Q      &kp W      &kp E      &kp R      &kp T
                &kp A      WHRML(S,         D,         F)      &kp G
                &kp Z      &kp X      &kp C      &kp V      &kp B
                &lt LEF TAB  &kp SPACE  &trans     &trans     &trans

                &kp Y      &kp U      &kp I      &kp O      &kp P
                &kp H      WHRMR(J,         K,         L)      &kp QUOTE
                &kp N      &kp M      &kp COMMA  &kp DOT    &kp SLASH
                &kp BSPC   &lt RIG TAB  &trans     &trans     &trans
            >;
        };

        // Navigation + mouse‑wheel + media (QMK layer 1)
        right_layer {
            bindings = <
                // Left side – 7 8 9 + ESC / 0 1 2 3 4 + big keys
                &kp ESC    &kp N7     &kp N8     &kp N9     &mt_sft N5
                &kp FSLH   &kp N4     &mt_sft N5  &kp N6     &kp SEMI
                &kp N0     &kp N1     &kp N2     &kp N3     &kp DOT
                &df 0       &kp SPACE  &trans     &trans     &trans

                // Right side – thumb cluster + mouse wheel + buttons + nav
                &mt_wh_u  &kp BTN1   &kp UARW   &kp BTN2   &kp ENTER
                &mt_wh_d  &kp LARW   &kp DARW   &kp RARW   &kp DEL
                &mt_wh_l  &mt_wh_r  &trans     &trans     &kp LALT_ENTER
                &kp BSPC   &df 2       &trans     &trans     &trans
            >;
        };

        // System / caps / mouse movement (QMK layer 2)
        left_layer {
            bindings = <
                // Left side – LCTL shortcuts + symbols + caps
                &kp ESC    &mt_ctl W  &trans     &kp GRAVE  &mt_sft GRAVE
                &mt_ctl A   &trans      &trans     &trans     &kp CAPSLOCK
                &mt_ctl Z   &mt_ctl X   &mt_ctl C   &mt_ctl V   &kp PSCRN
                &df 1       &kp SPACE  &trans     &trans     &trans

                // Right side – mouse wheel + pointer + page keys
                &mt_wh_u  &kp BTN1   &kp MS_U   &kp BTN2   &kp PG_UP
                &mt_wh_d  &kp MS_L   &kp MS_D   &kp MS_R   &kp ENTER
                &mt_wh_l  &mt_wh_r  &trans     &trans     &kp LALT
                &kp BSPC   &df 2       &trans     &trans     &trans
            >;
        };

        // Audio / brightness / macros (QMK layer 3)
        tri_layer {
            bindings = <
                // Left side – audio + brightness + LCTL / LALT
                &trans    &mt_ctl EQUAL &kp C_VOL_UP &kp C_BRI_UP  &trans
                &trans    &mt_ctl MINUS &kp C_VOL_DN &kp C_BRI_DEC &trans
                &trans    &kp LCTRL    &kp LALT     &kp DEL       &macro M8
                &df 1       &kp SPACE  &trans     &trans     &trans

                // Right side – M0–M7, enter, wake, etc.
                &trans    &macro M6   &macro M3   &macro M5   &trans
                &macro M0  &macro M1   &macro M4   &macro M7   &kp WAKE
                &macro M2  &trans      &trans      &trans      &trans
                &kp BSPC   &df 2       &trans     &trans     &trans
            >;
        };

        // Transparent layers 4 and 5 (as in your QMK layout)
        transparent_layer_4 {
            bindings = <
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
            >;
        };

        transparent_layer_5 {
            bindings = <
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans
            >;
        };
    };

    // Macros (from your QMK `macro` array)
    // M0–M9 can be fleshed out with `&macro_tap` and `&macro_text` as needed.
    macros {
        // Example: M0: HKJC entries (text automation)
        M0: macro_0 {
            compatible = "zmk,behavior-macro";
            labels = "HKJC_ENTRIES";
            #macro‑cells = <0>;
            bindings = <&macro_text "https://racing.hkjc.com/racing/information/Chinese/racing/Entries.aspx">, &kp ENTER>;
        };

        M1: macro_1 {
            compatible = "zmk,behavior-macro";
            labels = "HKJC_RACECARD";
            #macro‑cells = <0>;
            bindings = <&macro_text "https://racing.hkjc.com/racing/information/Chinese/racing/Racecard.aspx">, &kp ENTER>;
        };

        // Add M2–M8 similar to your QMK macros (SQL, URLs, logins, etc.).
    };
};
